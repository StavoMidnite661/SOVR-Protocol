{
  "name": "@sovr/runtime",
  "version": "0.6.0",
  "description": "SOVR Financial OS Runtime — Linux kernel of finance, machine-readable, unfakeable",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node dist/index.js",
    "server": "node dist/server/index.js",
    "server:dev": "tsx src/server/index.ts",
    "boot": "node dist/server/index.js",
    "test": "vitest run",
    "test:integration": "vitest run test/integration.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "ioredis": "^5.0.0",
    "js-yaml": "^4.1.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.22.0",
    "ws": "^8.18.0",
    "zod": "^3.22.0",
    "@sovr/shared": "file:../shared"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "fastify": "^4.28.1",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  }
}

{
  "name": "@sovr/compiler",
  "version": "0.6.0",
  "description": "SOVR Protocol Compiler — deterministic, unfakeable, machine-readable kernel compiler",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sovr": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "compile": "node dist/cli.js compile",
    "verify": "node dist/cli.js verify",
    "test": "node scripts/verify-spec.mjs",
    "test:genesis": "node scripts/verify-spec.mjs genesis",
    "test:fault": "node scripts/verify-spec.mjs fault",
    "test:stress": "node scripts/verify-spec.mjs stress",
    "test:integration": "node scripts/verify-spec.mjs integration"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "@sovr/shared": "file:../shared"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/js-yaml": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

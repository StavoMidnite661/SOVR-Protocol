# SOVR Financial OS — Production environment template
# Copy to .env and adjust for your deployment.

# --- Core -------------------------------------------------------------------
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
SOVR_LOG_LEVEL=info

# --- JWT (REQUIRED in production) -------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 bytes (256 bits) for HS256.
SOVR_JWT_SECRET=__REPLACE_WITH_BASE64_48_BYTES__
SOVR_JWT_ISSUER=sovr-financial-os
SOVR_JWT_AUDIENCE=sovr-clients
SOVR_JWT_TTL_SECONDS=3600

# --- Capability engine ------------------------------------------------------
# MUST be false in production. Setting true violates INV-003/004.
SOVR_DEV_AUTO_GRANT=false

# --- Kafka publisher (optional) --------------------------------------------
# When enabled, every event is published to topic sovr.{domain}.{aggregate}.{event_name}
SOVR_KAFKA_ENABLED=false
SOVR_KAFKA_BROKERS=broker1:9092,broker2:9092
SOVR_KAFKA_CLIENT_ID=sovr-runtime

# --- Redis stream publisher (optional) -------------------------------------
# When enabled, every event is XADDed to sovr:stream:{domain}:{aggregate}
SOVR_REDIS_ENABLED=false
SOVR_REDIS_URL=redis://localhost:6379
SOVR_REDIS_STREAM_MAXLEN=100000

# --- ACH boundary adapter (mock bank) --------------------------------------
SOVR_ACH_ROUTING_NUMBER=021000021
SOVR_ACH_BANK_NAME=SOVR Sandbox Bank
SOVR_ACH_LATENCY_MS=50
